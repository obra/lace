{
  "name": "@lace/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Out-of-process Lace agent runtime (Ent protocol over stdio)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "lace-agent": "dist/main.js"
  },
  "engines": {
    "node": ">=20.18.3"
  },
  "scripts": {
    "prebuild": "cd ../.. && npm run build --workspace=packages/ent-protocol",
    "build": "rm -f tsconfig.tsbuildinfo && tsc && tsc-alias -p tsconfig.json -f -fe .js && mkdir -p dist/providers/catalog && cp -r src/providers/catalog/data dist/providers/catalog/ && rm -rf dist/config/agent-personas && mkdir -p dist/config && cp -r config/agent-personas dist/config/",
    "build:clean": "rm -rf dist tsconfig.tsbuildinfo && npm run build",
    "pretest": "cd ../.. && npm run build --workspace=packages/ent-protocol && npm run build --workspace=packages/agent",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --ignore-path ../../.prettierignore --write \"src/**/*.{ts,js,json}\" \"**/*.{json,md,yml,yaml}\"",
    "test": "vitest run --exclude 'src/__tests__/**' --exclude src/containers/apple-container.integration.test.ts --exclude src/containers/container-cleanup-validation.test.ts --exclude src/jobs/__tests__/persona-container-sharing.integration.test.ts && vitest run --no-file-parallelism src/__tests__/ src/containers/apple-container.integration.test.ts src/containers/container-cleanup-validation.test.ts src/jobs/__tests__/persona-container-sharing.integration.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.29.2",
    "@anthropic-ai/sdk": "^0.98.0",
    "@google/genai": "^1.19.0",
    "@lace/ent-protocol": "file:../ent-protocol",
    "@lmstudio/sdk": "^1.2.1",
    "@modelcontextprotocol/sdk": "^1.17.5",
    "better-sqlite3": "^12.10.0",
    "cron-parser": "^5.5.0",
    "gray-matter": "^4.0.3",
    "mustache": "^4.2.0",
    "node-fetch": "^3.3.2",
    "ollama": "^0.5.16",
    "openai": "^6.27.0",
    "tiktoken": "^1.0.22",
    "turndown": "^7.2.0",
    "uuid": "^11.0.5",
    "zod": "^3.25.69",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mustache": "^4.2.5",
    "@types/node": "^22.16.0",
    "@types/turndown": "^5.0.5",
    "@vitest/coverage-v8": "^3.2.3",
    "jscpd": "^4.0.5",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./utils/logger": {
      "types": "./dist/utils/logger.d.ts",
      "import": "./dist/utils/logger.js"
    },
    "./utils/traffic-logger": {
      "types": "./dist/utils/traffic-logger.d.ts",
      "import": "./dist/utils/traffic-logger.js"
    }
  }
}
