#!/usr/bin/env node
// ABOUTME: One-shot-exec tool that summarises the working directory: file counts by
// ABOUTME: extension, total byte count, and the N largest files. Persona-aware: the
// ABOUTME: "debug" persona gets relative paths; all others get basenames only.
// ABOUTME: Node stdlib only — no external npm deps. ESM syntax required because the
// ABOUTME: packages/agent package.json sets "type": "module".

import * as fs from 'node:fs';
import * as path from 'node:path';
import * as readline from 'node:readline';

// ---------------------------------------------------------------------------
// Schema
// ---------------------------------------------------------------------------
const SCHEMA = {
  name: 'workspace/stats',
  description:
    'Summarise the current working directory: file counts by extension, total byte usage, ' +
    'and the N largest files. Persona-aware: "debug" persona gets relative paths.',
  inputSchema: {
    type: 'object',
    properties: {
      top_n: {
        type: 'integer',
        description: 'How many largest files to list (1–50, default 10)',
      },
      max_depth: {
        type: 'integer',
        description: 'Directory recursion depth (1–20, default 5)',
      },
    },
    required: [],
  },
};

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

/**
 * Walk a directory tree up to maxDepth, collecting {path, size} for every
 * regular file. Symlinks are not followed to avoid loops.
 */
function walk(dir, maxDepth, depth, results) {
  if (depth > maxDepth) return;
  let entries;
  try {
    entries = fs.readdirSync(dir, { withFileTypes: true });
  } catch {
    return; // unreadable dir — skip silently
  }
  for (const e of entries) {
    const full = path.join(dir, e.name);
    if (e.isSymbolicLink()) continue;
    if (e.isDirectory()) {
      walk(full, maxDepth, depth + 1, results);
    } else if (e.isFile()) {
      let size = 0;
      try {
        size = fs.statSync(full).size;
      } catch {
        /* skip unreadable files */
      }
      results.push({ path: full, size });
    }
  }
}

function formatBytes(n) {
  if (n < 1024) return `${n} B`;
  if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`;
  return `${(n / (1024 * 1024)).toFixed(1)} MB`;
}

function extOf(p) {
  const ext = path.extname(p);
  return ext === '' ? '(no ext)' : ext.toLowerCase();
}

// ---------------------------------------------------------------------------
// Subcommand: lace-tool-schema
// ---------------------------------------------------------------------------
if (process.argv[2] === 'lace-tool-schema') {
  process.stdout.write(JSON.stringify(SCHEMA));
  process.exit(0);
}

// ---------------------------------------------------------------------------
// Subcommand: lace-tool-invoke
// ---------------------------------------------------------------------------
if (process.argv[2] === 'lace-tool-invoke') {
  let raw = '';
  const rl = readline.createInterface({ input: process.stdin, terminal: false });
  rl.on('line', (line) => {
    raw += line + '\n';
  });
  rl.on('close', () => {
    let parsed;
    try {
      parsed = JSON.parse(raw);
    } catch {
      process.stderr.write('invalid JSON on stdin\n');
      process.exit(1);
    }

    const input = parsed.input ?? {};
    const context = parsed.context ?? {};
    const persona = typeof context.persona === 'string' ? context.persona : '';

    // Validate top_n
    let topN = 10;
    if (input.top_n !== undefined) {
      const n = Number(input.top_n);
      if (!Number.isInteger(n) || n < 1 || n > 50) {
        process.stderr.write('top_n must be an integer between 1 and 50\n');
        process.exit(1);
      }
      topN = n;
    }

    // Validate max_depth
    let maxDepth = 5;
    if (input.max_depth !== undefined) {
      const d = Number(input.max_depth);
      if (!Number.isInteger(d) || d < 1 || d > 20) {
        process.stderr.write('max_depth must be an integer between 1 and 20\n');
        process.exit(1);
      }
      maxDepth = d;
    }

    const cwd = process.cwd();
    const files = [];
    walk(cwd, maxDepth, 0, files);

    if (files.length === 0) {
      const result = {
        content: 'No files found in working directory.',
        metadata: { cwd, persona },
      };
      process.stdout.write(JSON.stringify(result));
      process.exit(0);
    }

    // Counts and sizes by extension
    const byExt = {};
    let totalBytes = 0;
    for (const f of files) {
      const ext = extOf(f.path);
      if (!byExt[ext]) byExt[ext] = { count: 0, bytes: 0 };
      byExt[ext].count++;
      byExt[ext].bytes += f.size;
      totalBytes += f.size;
    }

    const extRows = Object.entries(byExt)
      .sort((a, b) => b[1].count - a[1].count)
      .map(
        ([ext, { count, bytes }]) =>
          `  ${ext.padEnd(14)} ${String(count).padStart(5)} files  ${formatBytes(bytes)}`
      )
      .join('\n');

    // Largest files — persona "debug" gets relative paths, others get basenames
    const showRelativePaths = persona === 'debug';
    const largest = [...files]
      .sort((a, b) => b.size - a.size)
      .slice(0, topN)
      .map((f) => {
        const name = showRelativePaths ? path.relative(cwd, f.path) : path.basename(f.path);
        return `  ${formatBytes(f.size).padStart(10)}  ${name}`;
      })
      .join('\n');

    const lines = [
      `Workspace: ${cwd}`,
      `Persona:   ${persona || '(none)'}`,
      `Files:     ${files.length} total, ${formatBytes(totalBytes)}`,
      '',
      'By extension:',
      extRows,
      '',
      `Top ${topN} largest files:`,
      largest,
    ];

    const content = lines.join('\n');
    const result = {
      content,
      metadata: {
        cwd,
        persona,
        file_count: files.length,
        total_bytes: totalBytes,
      },
    };
    process.stdout.write(JSON.stringify(result));
    process.exit(0);
  });
} else {
  process.stderr.write(`usage: ${process.argv[1]} lace-tool-schema|lace-tool-invoke\n`);
  process.exit(2);
}
