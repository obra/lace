{
  "name": "@lace/supervisor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Supervisor process that spawns and coordinates out-of-process agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20.18.3"
  },
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json -f -fe .js",
    "build:clean": "rm -rf dist && npm run build",
    "pretest": "cd ../.. && npm run build --workspace=packages/ent-protocol && npm run build --workspace=packages/agent && npm run build --workspace=packages/supervisor",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --ignore-path ../../.prettierignore --write \"src/**/*.{ts,js,json}\" \"**/*.{json,md,yml,yaml}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lace/ent-protocol": "file:../ent-protocol"
  },
  "devDependencies": {
    "@types/node": "^22.16.0",
    "typescript": "^5.6.0",
    "tsc-alias": "^1.8.16",
    "vitest": "^3.2.4"
  }
}
