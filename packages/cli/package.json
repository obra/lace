{
  "name": "@lace/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Ent protocol CLI client (REPL) for driving Ent-protocol-speaking agents over stdio",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "lace": "dist/main.js"
  },
  "engines": {
    "node": ">=20.18.3"
  },
  "scripts": {
    "prebuild": "cd ../.. && npm run build --workspace=packages/ent-protocol",
    "build": "tsc && tsc-alias -p tsconfig.json -f -fe .js",
    "build:clean": "rm -rf dist && npm run build",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/main.ts"
  },
  "dependencies": {
    "@lace/ent-protocol": "file:../ent-protocol"
  },
  "devDependencies": {
    "@types/node": "^22.16.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.6.0"
  }
}

