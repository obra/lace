{
  "name": "lace-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lace AI coding assistant monorepo",
  "author": "Jesse Vincent <jesse@fsck.com>",
  "engines": {
    "node": ">=20.18.3",
    "bun": ">=1.2.21"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/ent-protocol && npm run build --workspace=packages/agent && npm run build --workspace=packages/cli",
    "dev": "npm run dev --workspace=packages/cli",
    "typecheck": "npm run typecheck --workspace=packages/ent-protocol && npm run typecheck --workspace=packages/agent && npm run typecheck --workspace=packages/cli",
    "lint": "npm run lint --workspace=packages/agent && npm run lint --workspace=packages/ent-protocol",
    "lint:fix": "npm run lint:fix --workspace=packages/agent && npm run lint:fix --workspace=packages/ent-protocol",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,scss,html,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,scss,html,yml,yaml}\"",
    "knip": "npx knip --isolate-workspaces",
    "knip:ci": "npx knip --isolate-workspaces --reporter json > knip-report.json || true",
    "prepare": "husky",
    "test": "npm run test --workspace=packages/ent-protocol && npm run test --workspace=packages/agent && npm run test --workspace=packages/cli",
    "test:run": "npm -ws --if-present run test:run",
    "test:watch": "npm run test:watch --workspace=packages/agent",
    "test:coverage": "npm run test:coverage --workspace=packages/agent",
    "update-catalogs": "npx tsx scripts/update-provider-catalogs.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@google/genai": "^1.19.0",
    "@lmstudio/sdk": "^1.2.1",
    "@typescript-eslint/utils": "^8.39.1",
    "mustache": "^4.2.0",
    "node-fetch": "^3.3.2",
    "ollama": "^0.5.16",
    "openai": "^6.27.0",
    "turndown": "^7.2.0",
    "uuid": "^13.0.0",
    "zod": "^3.25.69",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/bun": "^1.3.14",
    "@types/mustache": "^4.2.5",
    "@types/node": "^22.16.0",
    "@types/turndown": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitest/coverage-v8": "^3.2.3",
    "@vitest/eslint-plugin": "^1.3.4",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-prettier": "^5.4.1",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "knip": "^5.62.0",
    "lint-staged": "^16.1.1",
    "msw": "^2.10.4",
    "prettier": "^3.5.3",
    "ts-morph": "^27.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.36.0",
    "vitest": "^3.2.3"
  },
  "trustedDependencies": [
    "esbuild",
    "msw",
    "oxc-resolver"
  ]
}
