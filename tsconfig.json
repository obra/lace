{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": "./packages/agent/src",
    "paths": {
      "~/*": ["./*"]
    }
  },
  "include": [
    "src/**/*",
    "types/**/*",
    "tests/scenarios/persona-path-migration-baseline/capture.ts"
  ],
  "exclude": ["node_modules", "dist", "packages", "knip.config.ts", "production-build.test.ts"]
}
